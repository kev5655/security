   "source": [
    "import math\n",
    "\n",
    "def euclid(a: int, b: int) -> int:\n",
    "    if b < a:\n",
    "        a, b = b, a\n",
    "    \n",
    "    r = b % a\n",
    "    if r == 0:\n",
    "        return a\n",
    "    else:\n",
    "        return euclid(r, a)\n",
    "    \n",
    "print(f\"{euclid(48, 174)} == {math.gcd(48, 174)}\")\n",
    "assert euclid(48, 174) == math.gcd(48, 174), \"wrong calc\""
   ]
  },
